{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://craftengine.dev/schemas/sections/items.schema.json",
  "title": "Items Configuration",
  "description": "Item definition section.\n\nSupports version-conditional sections with $$version#section-id: format.",
  "type": "object",
  "patternProperties": {
    "^[a-z][a-z0-9_-]*:[a-z][a-z0-9_/-]*$": {
      "$ref": "#/$defs/itemConfig"
    },
    "^\\$\\$(>=|<=|<|=)?\\d+\\.\\d+(\\.\\d+)?(~\\d+\\.\\d+(\\.\\d+)?)?#[a-z][a-z0-9_-]*$": {
      "description": "Version-conditional section (e.g., $$>=1.21.4#topaz_trident:)\n\nContains item definitions that only apply to specific Minecraft versions.",
      "type": "object",
      "x-completion-key": "craftengine.versionCondition",
      "patternProperties": {
        "^[a-z][a-z0-9_-]*:[a-z][a-z0-9_/-]*$": {
          "$ref": "#/$defs/itemConfig"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "itemConfig": {
      "type": "object",
      "description": "Item configuration.\n\nSupports version-conditional block merging with $$>=1.21.4: keys.",
      "allOf": [
        {
          "$ref": "../common/universal-keys.schema.json#/$defs/templateSupport"
        },
        {
          "$ref": "#/$defs/itemProperties"
        }
      ],
      "patternProperties": {
        "^\\$\\$(>=|<=|<|=)?\\d+\\.\\d+(\\.\\d+)?(~\\d+\\.\\d+(\\.\\d+)?)?(#[a-z][a-z0-9_-]*)?$": {
          "description": "Version-conditional configuration block",
          "$ref": "#/$defs/itemProperties",
          "x-completion-key": "craftengine.versionCondition"
        }
      },
      "required": ["material"]
    },
    "itemProperties": {
      "type": "object",
      "properties": {
        "material": {
          "type": "string",
          "$ref": "../common/naming.schema.json#/$defs/minecraftMaterial",
          "description": "Base material (Minecraft Material enum)",
          "examples": ["DIAMOND_SWORD", "NETHERITE_PICKAXE"]
        },
        "client-bound-material": {
          "oneOf": [
            { "type": "string" },
            { "$ref": "../common/patterns.schema.json#/$defs/versionConditionalValue" }
          ],
          "description": "Client-bound material (supports version-conditional values)"
        },
        "custom-model-data": {
          "type": "integer",
          "description": "Custom model data value"
        },
        "category": {
          "type": "string",
          "$ref": "../common/base.schema.json#/$defs/categoryReference",
          "description": "Item category reference"
        },
        "client-bound-data": {
          "$ref": "#/$defs/clientBoundData"
        },
        "data": {
          "$ref": "../types/data.schema.json"
        },
        "settings": {
          "$ref": "../types/settings.schema.json"
        },
        "model": {
          "oneOf": [
            {
              "$ref": "../types/model.schema.json#/$defs/modelConfig"
            },
            {
              "type": "object",
              "description": "Version-conditional model (use $$>=1.21.4 key)"
            }
          ],
          "description": "Model configuration (1.21.4+)"
        },
        "legacy-model": {
          "$ref": "../types/model.schema.json#/$defs/legacyModel",
          "description": "Legacy model configuration (1.21.3 and earlier)"
        }
      }
    },
    "clientBoundData": {
      "type": "object",
      "description": "Client-bound data (client-side only configuration)",
      "allOf": [
        {
          "$ref": "../common/universal-keys.schema.json#/$defs/templateSupport"
        },
        {
          "type": "object",
          "properties": {
            "components": {
              "$ref": "../types/components.schema.json#/$defs/minecraftComponents"
            }
          }
        }
      ]
    }
  }
}

